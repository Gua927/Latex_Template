% Footer

% Set Margins around footer
\setbeamertemplate{footline}{
\hspace*{10mm}
{\scshape \insertshortauthor \hfill \insertshorttitle \hfill \insertframenumber{} / \inserttotalframenumber}
\hspace*{10mm} 
\vspace*{0.6cm}
}

\mode<all>
